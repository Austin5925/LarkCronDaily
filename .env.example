# Lark (Feishu) App Credentials
# Create an app at https://open.feishu.cn/app
LARK_APP_ID=cli_xxxxxxxxxxxxxxxx
LARK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Bitable Identifiers
# app_token: from the Bitable URL — https://xxx.feishu.cn/base/{app_token}
# table_id:  from the URL query param — ?table={table_id}
BITABLE_APP_TOKEN=bascnXXXXXXXXXXXXXX
BITABLE_TABLE_ID=tblXXXXXXXXXXXXXX

# Date field name in your Bitable table (default: 日期)
DATE_FIELD_NAME=日期

# Lark API base URL
# China:         https://open.feishu.cn  (default)
# International: https://open.larksuite.com
LARK_API_BASE=https://open.feishu.cn

# Log file path (default: lark_daily_copy.log)
LOG_FILE=lark_daily_copy.log
